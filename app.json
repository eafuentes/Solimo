{
  "expo": {
    "name": "Solimo",
    "slug": "solimo",
    "version": "1.1.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-app-1024.png",
    "userInterfaceStyle": "light",
    "description": "Solimo - A delightful micro-learning app for kids 3-10 with one engaging activity per day. Voice-accessible, beautifully animated, and designed for parents who want screen time to actually matter.",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF9E6"
    },
    "ios": {
      "bundleIdentifier": "com.solimo.app",
      "teamId": "473PWD3Y94",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-app-1024.png",
        "backgroundColor": "#FFF9E6"
      },
      "package": "com.solimo.app",
      "versionCode": 3,
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.MODIFY_AUDIO_SETTINGS"]
    },
    "scheme": "solimo",
    "platforms": ["ios", "android", "web"],
    "plugins": ["expo-audio"],
    "owner": "fuentes-studio",
    "extra": {
      "eas": {
        "projectId": "7b83a3c8-73f2-4ef3-8188-038a39ffc0a5"
      }
    }
  }
}
